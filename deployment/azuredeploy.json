{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "projectName": {
      "type": "string",
      "defaultValue": "volleyball",
      "metadata": {
        "description": "Base name used to generate resource names."
      }
    },
    "location": {
      "type": "string",
      "defaultValue": "[resourceGroup().location]",
      "metadata": {
        "description": "Azure region for all resources."
      }
    },
    "acrSku": {
      "type": "string",
      "defaultValue": "Basic",
      "allowedValues": [
        "Basic",
        "Standard",
        "Premium"
      ],
      "metadata": {
        "description": "SKU tier for the Azure Container Registry."
      }
    },
    "videoBlobContainerName": {
      "type": "string",
      "defaultValue": "volleyball-videos",
      "metadata": {
        "description": "Name of the blob container for storing video files (triggers EventGrid)."
      }
    },
    "coordinationBlobContainerName": {
      "type": "string",
      "defaultValue": "coordination",
      "metadata": {
        "description": "Name of the blob container for function coordination logs and metadata."
      }
    },
    "detectionsBlobContainerName": {
      "type": "string",
      "defaultValue": "detections",
      "metadata": {
        "description": "Name of the blob container for player detection results (JSON)."
      }
    },
    "videoRecordsTableName": {
      "type": "string",
      "defaultValue": "videoprocessingrecords",
      "metadata": {
        "description": "Azure Table Storage table used to track uploaded video processing state."
      }
    },
    "convertQueueName": {
      "type": "string",
      "defaultValue": "video-convert-jobs",
      "metadata": {
        "description": "Azure Queue Storage queue consumed for 720p conversion jobs."
      }
    },
    "urlImportQueueName": {
      "type": "string",
      "defaultValue": "video-url-import-jobs",
      "metadata": {
        "description": "Azure Queue Storage queue consumed for URL import jobs before conversion."
      }
    },
    "trimQueueName": {
      "type": "string",
      "defaultValue": "video-trim-jobs",
      "metadata": {
        "description": "Azure Queue Storage queue consumed for trim jobs."
      }
    },
    "detectQueueName": {
      "type": "string",
      "defaultValue": "video-detect-jobs",
      "metadata": {
        "description": "Azure Queue Storage queue consumed for detect jobs after trimming succeeds."
      }
    },
    "videoUploadMaxBytes": {
      "type": "string",
      "defaultValue": "5368709120",
      "metadata": {
        "description": "Maximum allowed upload size for the web application in bytes."
      }
    }
  },
  "variables": {
    "webAppName": "[format('{0}-web', parameters('projectName'))]",
    "functionAppName": "[format('{0}-functions', parameters('projectName'))]",
    "webAppPlanName": "[format('{0}-web-plan', parameters('projectName'))]",
    "functionAppPlanName": "[format('{0}-func-plan', parameters('projectName'))]",
    "storageAccountName": "[format('{0}storage', replace(parameters('projectName'), '-', ''))]",
    "acrName": "[format('{0}acr', replace(parameters('projectName'), '-', ''))]",
    "appInsightsName": "[format('{0}-insights', parameters('projectName'))]",
    "logAnalyticsName": "[format('{0}-logs', parameters('projectName'))]",
    "functionAppImageName": "[format('{0}acr.azurecr.io/{0}-functions:latest', replace(parameters('projectName'), '-', ''))]",
    "workerImageName": "[format('{0}acr.azurecr.io/{0}-worker:latest', replace(parameters('projectName'), '-', ''))]",
    "workerBootstrapImageName": "mcr.microsoft.com/k8se/quickstart:latest",
    "containerAppEnvironmentName": "[format('{0}-cae', parameters('projectName'))]",
    "workerContainerAppName": "[format('{0}-video-worker', parameters('projectName'))]"
  },
  "resources": [
    {
      "type": "Microsoft.OperationalInsights/workspaces",
      "apiVersion": "2022-10-01",
      "name": "[variables('logAnalyticsName')]",
      "location": "[parameters('location')]",
      "properties": {
        "sku": {
          "name": "PerGB2018"
        },
        "retentionInDays": 30
      }
    },
    {
      "type": "Microsoft.Insights/components",
      "apiVersion": "2020-02-02",
      "name": "[variables('appInsightsName')]",
      "location": "[parameters('location')]",
      "kind": "web",
      "dependsOn": [
        "[resourceId('Microsoft.OperationalInsights/workspaces', variables('logAnalyticsName'))]"
      ],
      "properties": {
        "Application_Type": "web",
        "WorkspaceResourceId": "[resourceId('Microsoft.OperationalInsights/workspaces', variables('logAnalyticsName'))]"
      }
    },
    {
      "type": "Microsoft.Storage/storageAccounts",
      "apiVersion": "2023-01-01",
      "name": "[variables('storageAccountName')]",
      "location": "[parameters('location')]",
      "sku": {
        "name": "Standard_LRS"
      },
      "kind": "StorageV2",
      "properties": {
        "supportsHttpsTrafficOnly": true,
        "minimumTlsVersion": "TLS1_2",
        "allowBlobPublicAccess": false
      }
    },
    {
      "type": "Microsoft.Storage/storageAccounts/blobServices",
      "apiVersion": "2023-01-01",
      "name": "[format('{0}/default', variables('storageAccountName'))]",
      "dependsOn": [
        "[resourceId('Microsoft.Storage/storageAccounts', variables('storageAccountName'))]"
      ],
      "properties": {
        "cors": {
          "corsRules": [
            {
              "allowedOrigins": [
                "[format('https://{0}.azurewebsites.net', variables('webAppName'))]",
                "http://localhost:3000",
                "http://127.0.0.1:3000"
              ],
              "allowedMethods": [
                "GET",
                "HEAD",
                "OPTIONS",
                "PUT"
              ],
              "allowedHeaders": [
                "*"
              ],
              "exposedHeaders": [
                "*"
              ],
              "maxAgeInSeconds": 3600
            }
          ]
        }
      }
    },
    {
      "type": "Microsoft.Storage/storageAccounts/tableServices",
      "apiVersion": "2023-01-01",
      "name": "[format('{0}/default', variables('storageAccountName'))]",
      "dependsOn": [
        "[resourceId('Microsoft.Storage/storageAccounts', variables('storageAccountName'))]"
      ]
    },
    {
      "type": "Microsoft.Storage/storageAccounts/tableServices/tables",
      "apiVersion": "2023-01-01",
      "name": "[format('{0}/default/{1}', variables('storageAccountName'), parameters('videoRecordsTableName'))]",
      "dependsOn": [
        "[resourceId('Microsoft.Storage/storageAccounts/tableServices', variables('storageAccountName'), 'default')]"
      ]
    },
    {
      "type": "Microsoft.Storage/storageAccounts/queueServices",
      "apiVersion": "2023-01-01",
      "name": "[format('{0}/default', variables('storageAccountName'))]",
      "dependsOn": [
        "[resourceId('Microsoft.Storage/storageAccounts', variables('storageAccountName'))]"
      ]
    },
    {
      "type": "Microsoft.Storage/storageAccounts/queueServices/queues",
      "apiVersion": "2023-01-01",
      "name": "[format('{0}/default/{1}', variables('storageAccountName'), parameters('convertQueueName'))]",
      "dependsOn": [
        "[resourceId('Microsoft.Storage/storageAccounts/queueServices', variables('storageAccountName'), 'default')]"
      ]
    },
    {
      "type": "Microsoft.Storage/storageAccounts/queueServices/queues",
      "apiVersion": "2023-01-01",
      "name": "[format('{0}/default/{1}', variables('storageAccountName'), parameters('urlImportQueueName'))]",
      "dependsOn": [
        "[resourceId('Microsoft.Storage/storageAccounts/queueServices', variables('storageAccountName'), 'default')]"
      ]
    },
    {
      "type": "Microsoft.Storage/storageAccounts/queueServices/queues",
      "apiVersion": "2023-01-01",
      "name": "[format('{0}/default/{1}', variables('storageAccountName'), parameters('trimQueueName'))]",
      "dependsOn": [
        "[resourceId('Microsoft.Storage/storageAccounts/queueServices', variables('storageAccountName'), 'default')]"
      ]
    },
    {
      "type": "Microsoft.Storage/storageAccounts/queueServices/queues",
      "apiVersion": "2023-01-01",
      "name": "[format('{0}/default/{1}', variables('storageAccountName'), parameters('detectQueueName'))]",
      "dependsOn": [
        "[resourceId('Microsoft.Storage/storageAccounts/queueServices', variables('storageAccountName'), 'default')]"
      ]
    },
    {
      "type": "Microsoft.Storage/storageAccounts/blobServices/containers",
      "apiVersion": "2023-01-01",
      "name": "[format('{0}/default/{1}', variables('storageAccountName'), parameters('videoBlobContainerName'))]",
      "dependsOn": [
        "[resourceId('Microsoft.Storage/storageAccounts/blobServices', variables('storageAccountName'), 'default')]"
      ],
      "properties": {
        "publicAccess": "None"
      }
    },
    {
      "type": "Microsoft.Storage/storageAccounts/blobServices/containers",
      "apiVersion": "2023-01-01",
      "name": "[format('{0}/default/{1}', variables('storageAccountName'), parameters('coordinationBlobContainerName'))]",
      "dependsOn": [
        "[resourceId('Microsoft.Storage/storageAccounts/blobServices', variables('storageAccountName'), 'default')]"
      ],
      "properties": {
        "publicAccess": "None"
      }
    },
    {
      "type": "Microsoft.Storage/storageAccounts/blobServices/containers",
      "apiVersion": "2023-01-01",
      "name": "[format('{0}/default/{1}', variables('storageAccountName'), parameters('detectionsBlobContainerName'))]",
      "dependsOn": [
        "[resourceId('Microsoft.Storage/storageAccounts/blobServices', variables('storageAccountName'), 'default')]"
      ],
      "properties": {
        "publicAccess": "None"
      }
    },
    {
      "type": "Microsoft.ContainerRegistry/registries",
      "apiVersion": "2023-07-01",
      "name": "[variables('acrName')]",
      "location": "[parameters('location')]",
      "sku": {
        "name": "[parameters('acrSku')]"
      },
      "properties": {
        "adminUserEnabled": true
      }
    },
    {
      "type": "Microsoft.App/managedEnvironments",
      "apiVersion": "2024-03-01",
      "name": "[variables('containerAppEnvironmentName')]",
      "location": "[parameters('location')]",
      "dependsOn": [
        "[resourceId('Microsoft.OperationalInsights/workspaces', variables('logAnalyticsName'))]"
      ],
      "properties": {
        "appLogsConfiguration": {
          "destination": "log-analytics",
          "logAnalyticsConfiguration": {
            "customerId": "[reference(resourceId('Microsoft.OperationalInsights/workspaces', variables('logAnalyticsName')), '2022-10-01').customerId]",
            "sharedKey": "[listKeys(resourceId('Microsoft.OperationalInsights/workspaces', variables('logAnalyticsName')), '2022-10-01').primarySharedKey]"
          }
        }
      }
    },
    {
      "type": "Microsoft.Web/serverfarms",
      "apiVersion": "2023-01-01",
      "name": "[variables('webAppPlanName')]",
      "location": "[parameters('location')]",
      "kind": "linux",
      "sku": {
        "name": "B1",
        "tier": "Basic"
      },
      "properties": {
        "reserved": true
      }
    },
    {
      "type": "Microsoft.Web/sites",
      "apiVersion": "2023-01-01",
      "name": "[variables('webAppName')]",
      "location": "[parameters('location')]",
      "dependsOn": [
        "[resourceId('Microsoft.Web/serverfarms', variables('webAppPlanName'))]",
        "[resourceId('Microsoft.Insights/components', variables('appInsightsName'))]",
        "[resourceId('Microsoft.Storage/storageAccounts', variables('storageAccountName'))]"
      ],
      "properties": {
        "serverFarmId": "[resourceId('Microsoft.Web/serverfarms', variables('webAppPlanName'))]",
        "httpsOnly": true,
        "siteConfig": {
          "linuxFxVersion": "NODE|20-lts",
          "appCommandLine": "node dist/index.js",
          "appSettings": [
            {
              "name": "APPINSIGHTS_INSTRUMENTATIONKEY",
              "value": "[reference(resourceId('Microsoft.Insights/components', variables('appInsightsName'))).InstrumentationKey]"
            },
            {
              "name": "APPLICATIONINSIGHTS_CONNECTION_STRING",
              "value": "[reference(resourceId('Microsoft.Insights/components', variables('appInsightsName'))).ConnectionString]"
            },
            {
              "name": "AZURE_STORAGE_CONNECTION_STRING",
              "value": "[format('DefaultEndpointsProtocol=https;AccountName={0};AccountKey={1};EndpointSuffix=core.windows.net', variables('storageAccountName'), listKeys(resourceId('Microsoft.Storage/storageAccounts', variables('storageAccountName')), '2023-01-01').keys[0].value)]"
            },
            {
              "name": "SCM_DO_BUILD_DURING_DEPLOYMENT",
              "value": "false"
            },
            {
              "name": "VIDEO_BLOB_CONTAINER",
              "value": "[parameters('videoBlobContainerName')]"
            },
            {
              "name": "VIDEO_RECORDS_TABLE_NAME",
              "value": "[parameters('videoRecordsTableName')]"
            },
            {
              "name": "VIDEO_UPLOAD_MAX_BYTES",
              "value": "[parameters('videoUploadMaxBytes')]"
            },
            {
              "name": "VIDEO_URL_IMPORT_FUNCTION_URL",
              "value": "[format('https://{0}.azurewebsites.net/api/videos/import-from-url', variables('functionAppName'))]"
            }
          ]
        }
      }
    },
    {
      "type": "Microsoft.Web/sites/config",
      "apiVersion": "2023-01-01",
      "name": "[format('{0}/logs', variables('webAppName'))]",
      "dependsOn": [
        "[resourceId('Microsoft.Web/sites', variables('webAppName'))]"
      ],
      "properties": {
        "applicationLogs": {
          "fileSystem": {
            "level": "Verbose"
          }
        },
        "httpLogs": {
          "fileSystem": {
            "retentionInMb": 35,
            "retentionInDays": 3,
            "enabled": true
          }
        },
        "detailedErrorMessages": {
          "enabled": true
        },
        "failedRequestsTracing": {
          "enabled": true
        }
      }
    },
    {
      "type": "Microsoft.Web/serverfarms",
      "apiVersion": "2023-01-01",
      "name": "[variables('functionAppPlanName')]",
      "location": "[parameters('location')]",
      "kind": "linux",
      "sku": {
        "name": "B1",
        "tier": "Basic"
      },
      "properties": {
        "reserved": true
      }
    },
    {
      "type": "Microsoft.Web/sites",
      "apiVersion": "2023-01-01",
      "name": "[variables('functionAppName')]",
      "location": "[parameters('location')]",
      "kind": "functionapp,linux,container",
      "dependsOn": [
        "[resourceId('Microsoft.Web/serverfarms', variables('functionAppPlanName'))]",
        "[resourceId('Microsoft.Insights/components', variables('appInsightsName'))]",
        "[resourceId('Microsoft.Storage/storageAccounts', variables('storageAccountName'))]",
        "[resourceId('Microsoft.ContainerRegistry/registries', variables('acrName'))]"
      ],
      "properties": {
        "serverFarmId": "[resourceId('Microsoft.Web/serverfarms', variables('functionAppPlanName'))]",
        "httpsOnly": true,
        "siteConfig": {
          "linuxFxVersion": "[format('DOCKER|{0}', variables('functionAppImageName'))]",
          "appSettings": [
            {
              "name": "DOCKER_REGISTRY_SERVER_URL",
              "value": "[format('https://{0}.azurecr.io', variables('acrName'))]"
            },
            {
              "name": "DOCKER_REGISTRY_SERVER_USERNAME",
              "value": "[listCredentials(resourceId('Microsoft.ContainerRegistry/registries', variables('acrName')), '2023-07-01').username]"
            },
            {
              "name": "DOCKER_REGISTRY_SERVER_PASSWORD",
              "value": "[listCredentials(resourceId('Microsoft.ContainerRegistry/registries', variables('acrName')), '2023-07-01').passwords[0].value]"
            },
            {
              "name": "AzureWebJobsStorage",
              "value": "[format('DefaultEndpointsProtocol=https;AccountName={0};AccountKey={1};EndpointSuffix=core.windows.net', variables('storageAccountName'), listKeys(resourceId('Microsoft.Storage/storageAccounts', variables('storageAccountName')), '2023-01-01').keys[0].value)]"
            },
            {
              "name": "FUNCTIONS_EXTENSION_VERSION",
              "value": "~4"
            },
            {
              "name": "FUNCTIONS_WORKER_RUNTIME",
              "value": "node"
            },
            {
              "name": "WEBSITES_ENABLE_APP_SERVICE_STORAGE",
              "value": "false"
            },
            {
              "name": "APPINSIGHTS_INSTRUMENTATIONKEY",
              "value": "[reference(resourceId('Microsoft.Insights/components', variables('appInsightsName'))).InstrumentationKey]"
            },
            {
              "name": "APPLICATIONINSIGHTS_CONNECTION_STRING",
              "value": "[reference(resourceId('Microsoft.Insights/components', variables('appInsightsName'))).ConnectionString]"
            },
            {
              "name": "AZURE_STORAGE_CONNECTION_STRING",
              "value": "[format('DefaultEndpointsProtocol=https;AccountName={0};AccountKey={1};EndpointSuffix=core.windows.net', variables('storageAccountName'), listKeys(resourceId('Microsoft.Storage/storageAccounts', variables('storageAccountName')), '2023-01-01').keys[0].value)]"
            },
            {
              "name": "VIDEO_BLOB_CONTAINER",
              "value": "[parameters('videoBlobContainerName')]"
            },
            {
              "name": "COORDINATION_BLOB_CONTAINER",
              "value": "[parameters('coordinationBlobContainerName')]"
            },
            {
              "name": "DETECTIONS_BLOB_CONTAINER",
              "value": "[parameters('detectionsBlobContainerName')]"
            },
            {
              "name": "VIDEO_RECORDS_TABLE_NAME",
              "value": "[parameters('videoRecordsTableName')]"
            },
            {
              "name": "VIDEO_CONVERT_QUEUE_NAME",
              "value": "[parameters('convertQueueName')]"
            },
            {
              "name": "VIDEO_URL_IMPORT_QUEUE_NAME",
              "value": "[parameters('urlImportQueueName')]"
            },
            {
              "name": "VIDEO_TRIM_QUEUE_NAME",
              "value": "[parameters('trimQueueName')]"
            },
            {
              "name": "VIDEO_DETECT_QUEUE_NAME",
              "value": "[parameters('detectQueueName')]"
            },
            {
              "name": "VIDEO_UPLOAD_MAX_BYTES",
              "value": "[parameters('videoUploadMaxBytes')]"
            }
          ]
        }
      }
    },
    {
      "type": "Microsoft.Web/sites/config",
      "apiVersion": "2023-01-01",
      "name": "[format('{0}/logs', variables('functionAppName'))]",
      "dependsOn": [
        "[resourceId('Microsoft.Web/sites', variables('functionAppName'))]"
      ],
      "properties": {
        "applicationLogs": {
          "fileSystem": {
            "level": "Verbose"
          }
        },
        "httpLogs": {
          "fileSystem": {
            "retentionInMb": 35,
            "retentionInDays": 3,
            "enabled": true
          }
        },
        "detailedErrorMessages": {
          "enabled": true
        },
        "failedRequestsTracing": {
          "enabled": true
        }
      }
    },
    {
      "type": "Microsoft.App/containerApps",
      "apiVersion": "2024-03-01",
      "name": "[variables('workerContainerAppName')]",
      "location": "[parameters('location')]",
      "dependsOn": [
        "[resourceId('Microsoft.App/managedEnvironments', variables('containerAppEnvironmentName'))]",
        "[resourceId('Microsoft.ContainerRegistry/registries', variables('acrName'))]",
        "[resourceId('Microsoft.Storage/storageAccounts', variables('storageAccountName'))]"
      ],
      "properties": {
        "managedEnvironmentId": "[resourceId('Microsoft.App/managedEnvironments', variables('containerAppEnvironmentName'))]",
        "configuration": {
          "activeRevisionsMode": "Single",
          "secrets": [
            {
              "name": "acr-password",
              "value": "[listCredentials(resourceId('Microsoft.ContainerRegistry/registries', variables('acrName')), '2023-07-01').passwords[0].value]"
            },
            {
              "name": "storage-connection-string",
              "value": "[format('DefaultEndpointsProtocol=https;AccountName={0};AccountKey={1};EndpointSuffix=core.windows.net', variables('storageAccountName'), listKeys(resourceId('Microsoft.Storage/storageAccounts', variables('storageAccountName')), '2023-01-01').keys[0].value)]"
            }
          ],
          "registries": [
            {
              "server": "[format('{0}.azurecr.io', variables('acrName'))]",
              "username": "[listCredentials(resourceId('Microsoft.ContainerRegistry/registries', variables('acrName')), '2023-07-01').username]",
              "passwordSecretRef": "acr-password"
            }
          ]
        },
        "template": {
          "containers": [
            {
              "name": "video-worker",
              "image": "[variables('workerBootstrapImageName')]",
              "env": [
                {
                  "name": "AZURE_STORAGE_CONNECTION_STRING",
                  "secretRef": "storage-connection-string"
                },
                {
                  "name": "VIDEO_RECORDS_TABLE_NAME",
                  "value": "[parameters('videoRecordsTableName')]"
                },
                {
                  "name": "AZURE_STORAGE_INPUT_FOLDER",
                  "value": "input"
                },
                {
                  "name": "AZURE_STORAGE_OUTPUT_FOLDER",
                  "value": "processed"
                },
                {
                  "name": "AZURE_STORAGE_DETECTION_FOLDER",
                  "value": "detections"
                },
                {
                  "name": "AZURE_STORAGE_CONTAINER",
                  "value": "[parameters('videoBlobContainerName')]"
                },
                {
                  "name": "VIDEO_CONVERT_QUEUE_NAME",
                  "value": "[parameters('convertQueueName')]"
                },
                {
                  "name": "VIDEO_TRIM_QUEUE_NAME",
                  "value": "[parameters('trimQueueName')]"
                },
                {
                  "name": "VIDEO_DETECT_QUEUE_NAME",
                  "value": "[parameters('detectQueueName')]"
                }
              ],
              "resources": {
                "cpu": 1,
                "memory": "2Gi"
              }
            }
          ],
          "scale": {
            "minReplicas": 0,
            "maxReplicas": 3,
            "rules": [
              {
                "name": "convert-queue",
                "azureQueue": {
                  "queueName": "[parameters('convertQueueName')]",
                  "queueLength": 1,
                  "auth": [
                    {
                      "secretRef": "storage-connection-string",
                      "triggerParameter": "connection"
                    }
                  ]
                }
              },
              {
                "name": "trim-queue",
                "azureQueue": {
                  "queueName": "[parameters('trimQueueName')]",
                  "queueLength": 1,
                  "auth": [
                    {
                      "secretRef": "storage-connection-string",
                      "triggerParameter": "connection"
                    }
                  ]
                }
              },
              {
                "name": "detect-queue",
                "azureQueue": {
                  "queueName": "[parameters('detectQueueName')]",
                  "queueLength": 1,
                  "auth": [
                    {
                      "secretRef": "storage-connection-string",
                      "triggerParameter": "connection"
                    }
                  ]
                }
              }
            ]
          }
        }
      }
    }
  ],
  "outputs": {
    "webAppUrl": {
      "type": "string",
      "value": "[format('https://{0}.azurewebsites.net', variables('webAppName'))]"
    },
    "functionAppUrl": {
      "type": "string",
      "value": "[format('https://{0}.azurewebsites.net', variables('functionAppName'))]"
    },
    "storageAccountName": {
      "type": "string",
      "value": "[variables('storageAccountName')]"
    },
    "videoBlobContainerName": {
      "type": "string",
      "value": "[parameters('videoBlobContainerName')]"
    },
    "coordinationBlobContainerName": {
      "type": "string",
      "value": "[parameters('coordinationBlobContainerName')]"
    },
    "detectionsBlobContainerName": {
      "type": "string",
      "value": "[parameters('detectionsBlobContainerName')]"
    },
    "appInsightsInstrumentationKey": {
      "type": "string",
      "value": "[reference(resourceId('Microsoft.Insights/components', variables('appInsightsName'))).InstrumentationKey]"
    },
    "acrLoginServer": {
      "type": "string",
      "value": "[format('{0}.azurecr.io', variables('acrName'))]"
    },
    "acrName": {
      "type": "string",
      "value": "[variables('acrName')]"
    },
    "videoRecordsTableName": {
      "type": "string",
      "value": "[parameters('videoRecordsTableName')]"
    },
    "workerContainerAppName": {
      "type": "string",
      "value": "[variables('workerContainerAppName')]"
    },
    "convertQueueName": {
      "type": "string",
      "value": "[parameters('convertQueueName')]"
    },
    "urlImportQueueName": {
      "type": "string",
      "value": "[parameters('urlImportQueueName')]"
    },
    "trimQueueName": {
      "type": "string",
      "value": "[parameters('trimQueueName')]"
    },
    "detectQueueName": {
      "type": "string",
      "value": "[parameters('detectQueueName')]"
    }
  }
}
